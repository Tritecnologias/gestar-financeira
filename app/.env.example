# Variáveis de Ambiente - Gestar Financeira
# COPIE ESTE ARQUIVO PARA .env.local E PREENCHA OS VALORES

# ── Banco de Dados (PostgreSQL via Docker) ────────────────────
DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5433/gestar_financeira"

# ── NextAuth.js ───────────────────────────────────────────────
# Gere um secret seguro com: openssl rand -base64 32
NEXTAUTH_SECRET="TROQUE_POR_UM_SECRET_SEGURO_32_CHARS"
NEXTAUTH_URL="http://localhost:3000"

# ── Em produção (VPS), altere para: ──────────────────────────
# NEXTAUTH_URL="https://seudominio.com.br"
# DATABASE_URL="postgresql://USUARIO:SENHA@postgres:5432/gestar_financeira"
# (note: em Docker Compose, o host é o nome do serviço "postgres", não "localhost")
